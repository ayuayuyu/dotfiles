# --- tmux自動アタッチ (Ghostty起動時のみ) ---
if [[ -z "$TMUX" ]] && [[ "$TERM_PROGRAM" == "ghostty" ]] && command -v tmux &>/dev/null; then
  tmux attach -t main 2>/dev/null || tmux new -s main
fi

# --- シェルオプション ---
# History
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS HIST_FIND_NO_DUPS
setopt HIST_SAVE_NO_DUPS SHARE_HISTORY EXTENDED_HISTORY
setopt INC_APPEND_HISTORY HIST_REDUCE_BLANKS

# Directory
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT PUSHD_TO_HOME

# General
setopt INTERACTIVE_COMMENTS COMBINING_CHARS NO_BEEP

# --- sheldon (プラグインマネージャ) ---
eval "$(sheldon source)"

# --- 危険コマンドのハイライト (赤背景で警告) ---
ZSH_HIGHLIGHT_HIGHLIGHTERS+=(pattern)
typeset -A ZSH_HIGHLIGHT_PATTERNS
ZSH_HIGHLIGHT_PATTERNS+=('rm -rf *' 'fg=white,bold,bg=red')
ZSH_HIGHLIGHT_PATTERNS+=('rm -rf' 'fg=white,bold,bg=red')
ZSH_HIGHLIGHT_PATTERNS+=('chmod 777 *' 'fg=white,bold,bg=red')
ZSH_HIGHLIGHT_PATTERNS+=('chmod -R 777 *' 'fg=white,bold,bg=red')

# --- 補完 ---
autoload -Uz compinit && compinit

# --- ツール初期化 ---
eval "$(mise activate zsh)"

# --- vi モード: 挿入モード→ビームカーソル、ノーマルモード→ブロックカーソル ---
function zle-keymap-select {
  if [[ ${KEYMAP} == vicmd ]]; then
    echo -ne '\e[1 q'  # ブロック
  else
    echo -ne '\e[5 q'  # ビーム
  fi
}
zle -N zle-keymap-select
echo -ne '\e[5 q'

# --- git clone with ssh ---
function gitcloneHTTPS() {
  parts=(${(@s:/:)1})
  echo git@github.com:${(@j:/:)parts[3,4]}
  git clone git@github.com:${(@j:/:)parts[3,4]}
}
alias gc='gitcloneHTTPS $1'

# ----nvim: 起動----
alias vi=nvim

# --- tmux: 均等分割レイアウト ---
alias t4='~/dotfiles/scripts/tmux-4pane.sh'
alias t6='~/dotfiles/scripts/tmux-6pane.sh'
alias t6v='~/dotfiles/scripts/tmux-6vpane.sh'
alias t8='~/dotfiles/scripts/tmux-8pane.sh'

# --- eza: モダンなls ---
if command -v eza &>/dev/null; then
  alias ls='eza --icons'
  alias ll='eza -l --icons --git'
  alias la='eza -la --icons --git'
  alias lt='eza --tree --icons --level=2'
fi

# --- bat: シンタックスハイライト付きcat ---
if command -v bat &>/dev/null; then
  alias cat='bat --paging=never'
fi

# --- zoxide: スマートなcd (z でどこでも移動) ---
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# --- fzf: ファジーファインダー ---
if [[ -f ~/.fzf.zsh ]]; then
  source ~/.fzf.zsh
elif command -v fzf &>/dev/null; then
  source <(fzf --zsh)
fi

# --- history-substring-search キーバインド ---
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down
bindkey -M vicmd 'k' history-substring-search-up
bindkey -M vicmd 'j' history-substring-search-down

# --- SSH: TERM修正 (xterm-ghosttyはリモートで認識されないため) ---
if [[ "$TERM" == "xterm-ghostty" ]]; then
  alias ssh="TERM=xterm-256color ssh"
fi

# --- PATH ---
export PATH="${HOME}/.local/bin:${PATH}"

# --- Starship プロンプト ---
export STARSHIP_CONFIG="${HOME}/.config/starship.toml"
eval "$(starship init zsh)"

# ==========================================
# Aider + Llama 4 Scout (REDACTED_USER server)
# ==========================================
function aider-scout() {
    # 1. ローカルの11434ポートが使われているか（トンネルがあるか）確認
    if ! lsof -i:11434 -t >/dev/null 2>&1; then
        echo "REDACTED_USER（ITS）サーバーへSSHトンネルを接続しています..."
        ssh -N -f -L 11434:localhost:11434 REDACTED_USER@REDACTED_HOST
    fi

    # 2. 環境変数をセットしてAiderを起動（引数も渡せるように $@ を付与）
    export OLLAMA_API_BASE=http://localhost:11434
    echo "Llama 4 Scout (Aider) を起動します..."
    aider --model ollama/yasserrmd/Llama-4-Scout-17B-16E-Instruct "$@"
}

# =============================================================================
# SSH Configuration (dotfiles管理)
# 個別ホスト設定は ~/.ssh/config.local に記述
# =============================================================================

# --- ローカル設定を読み込み ---
Include config.local

# --- 全ホスト共通 ---
Host *
  # 接続維持 (60秒ごとにキープアライブ、3回失敗で切断)
  ServerAliveInterval 60
  ServerAliveCountMax 3
  # SSH鍵をエージェントに自動追加
  AddKeysToAgent yes
  # macOS: キーチェーンに保存 (Linux では無視される)
  IgnoreUnknown UseKeychain
  UseKeychain yes
  # 接続の多重化 (同一ホストへの2回目以降の接続が高速化)
  ControlMaster auto
  ControlPath ~/.ssh/sockets/%r@%h-%p
  ControlPersist 600
  # デフォルト鍵
  IdentityFile ~/.ssh/id_ed25519

# --- GitHub ---
Host github.com
  HostName github.com
  User git

# --- 内部ホスト (Host llm 等) は ~/.ssh/config.local に記述する ---
